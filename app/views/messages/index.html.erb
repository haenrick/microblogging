<div class="feed-tabs">
  <%= link_to notifications_path, class: "feed-tab" do %>
    notifications
    <%= render "notifications/badge", unread_count: Current.user.notifications.unread.count %>
  <% end %>
  <%= link_to messages_path, class: "feed-tab active" do %>
    messages
    <% unread_dm = Current.user.unread_messages_count %>
    <% if unread_dm > 0 %>
      <span class="notif-badge"><%= unread_dm %></span>
    <% end %>
  <% end %>
</div>

<% if @messageable.any? %>
  <div class="new-message-bar" data-controller="toggle">
    <button class="btn-ghost btn-small" data-action="click->toggle#toggle" data-toggle-target="trigger">
      // new message
    </button>
    <div class="new-message-form hidden" data-toggle-target="content">
      <%= form_with url: new_message_conversation_path, method: :get, class: "new-message-select-form" do |f| %>
        <%= f.select :username,
            @messageable.map { |u| ["@#{u.username}", u.username] },
            { prompt: "Follower auswählen …" },
            { class: "select-input" } %>
        <%= f.submit "// start", class: "btn-primary btn-small" %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @conversations.empty? %>
  <p class="empty-state">// keine Konversationen — schreibe jemanden an, der dir folgt</p>
<% else %>
  <div class="conversations-list">
    <% @conversations.each do |conv| %>
      <%= link_to message_path(conv[:partner].username), class: "conversation-item #{conv[:unread] ? "unread" : ""}" do %>
        <div class="conv-avatar">
          <% if conv[:partner].avatar.attached? %>
            <%= image_tag conv[:partner].avatar_thumbnail, class: "avatar-img avatar-small" %>
          <% else %>
            <div class="avatar-initials avatar-small"><%= conv[:partner].initials %></div>
          <% end %>
        </div>
        <div class="conv-body">
          <div class="conv-header">
            <span class="conv-username">@<%= conv[:partner].username %></span>
            <span class="conv-time dim"><%= time_ago_in_words(conv[:last_message].created_at) %> ago</span>
          </div>
          <p class="conv-preview dim"><%= truncate(conv[:last_message].content, length: 60) %></p>
        </div>
        <% if conv[:unread] %>
          <span class="conv-unread-dot"></span>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
