<div class="session-form">
  <h1>Edit profile</h1>

  <%= form_with model: @user, url: update_profile_path, method: :patch, multipart: true do |f| %>
    <% if @user.errors.any? %>
      <div class="error"><%= @user.errors.full_messages.to_sentence %></div>
    <% end %>

    <div class="form-group avatar-upload">
      <label>Profile picture</label>
      <div class="avatar-preview">
        <% if @user.avatar.attached? %>
          <%= image_tag @user.avatar_thumbnail, class: "avatar-img" %>
        <% else %>
          <div class="avatar-initials"><%= @user.initials %></div>
        <% end %>
      </div>
      <%= f.file_field :avatar, accept: "image/*", class: "file-input" %>
    </div>

    <div class="form-group">
      <%= f.label :bio, "Bio (max. 160 characters)" %>
      <%= f.text_area :bio, rows: 3, maxlength: 160, placeholder: "Tell something about yourself...", class: "bio-input" %>
    </div>

    <%= f.submit "Save", class: "btn-primary" %>
    <%= link_to "Cancel", profile_path(@user.username), class: "btn-ghost" %>
  <% end %>
</div>
