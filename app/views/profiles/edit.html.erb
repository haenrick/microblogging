<h2 class="page-title">Settings</h2>

<div class="settings-form">
  <%= form_with model: @user, url: update_profile_path, method: :patch, multipart: true do |f| %>
    <% if @user.errors.any? %>
      <div class="error"><%= @user.errors.full_messages.to_sentence %></div>
    <% end %>

    <div class="settings-section">
      <h3>Profile</h3>
      <%= link_to "→ View your profile", profile_path(@user.username), class: "profile-link" %>
    </div>

    <div class="settings-section">
      <h3>Profile picture</h3>
      <div class="avatar-upload">
        <div class="avatar-preview">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar_thumbnail, class: "avatar-img avatar-large" %>
          <% else %>
            <div class="avatar-initials avatar-large"><%= @user.initials %></div>
          <% end %>
        </div>
        <%= f.file_field :avatar, accept: "image/*", class: "file-input" %>
      </div>
    </div>

    <div class="settings-section">
      <h3>Bio</h3>
      <%= f.text_area :bio, rows: 4, maxlength: 160,
          placeholder: "Tell something about yourself...",
          class: "bio-input" %>
      <span class="hint">Max. 160 characters</span>
    </div>

    <div class="settings-section">
      <h3>Terminal color</h3>
      <div class="theme-picker">
        <% User::THEMES.each do |name, _| %>
          <label class="theme-swatch-label">
            <%= f.radio_button :theme, name, class: "theme-radio" %>
            <span class="theme-swatch theme-swatch-<%= name %>" title="<%= name %>"></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="settings-section">
      <h3>Preferences</h3>
      <div class="preference-list">
        <label class="preference-item">
          <%= f.check_box :enter_to_post, class: "preference-checkbox" %>
          <span>
            <strong>Submit post with Enter</strong>
            <span class="hint">When off, use Shift+Enter to post (Enter adds a new line)</span>
          </span>
        </label>
      </div>
    </div>

    <div class="settings-actions">
      <%= f.submit "Save changes", class: "btn-primary" %>
    </div>
  <% end %>
</div>

<div class="settings-form">
  <div class="settings-section">
    <h3>Change password</h3>
    <%= form_with url: change_password_path, method: :patch do |f| %>
      <div class="stacked-fields">
        <%= f.password_field :current_password, placeholder: "Current password", class: "settings-input" %>
        <%= f.password_field :password, placeholder: "New password (min. 8 chars)", class: "settings-input" %>
        <%= f.password_field :password_confirmation, placeholder: "Repeat new password", class: "settings-input" %>
      </div>
      <div class="settings-actions">
        <%= f.submit "Change password", class: "btn-ghost" %>
      </div>
    <% end %>
  </div>
</div>

<% if Current.user.blocked_users.any? %>
  <div class="settings-form">
    <div class="settings-section">
      <h3>Blocked users</h3>
      <div class="block-list">
        <% Current.user.blocked_users.each do |user| %>
          <div class="block-list-item">
            <%= link_to "@#{user.username}", profile_path(user.username), class: "username" %>
            <%= button_to "Unblock", unblock_user_path(user.username), method: :delete, class: "btn-ghost btn-small" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<div class="settings-form danger-zone">
  <div class="settings-section">
    <h3>Delete account</h3>
    <p class="hint">Permanently deletes your account, all posts, likes and follows. This cannot be undone.</p>
    <%= form_with url: delete_account_path, method: :delete do |f| %>
      <div class="stacked-fields">
        <%= f.password_field :password, placeholder: "Confirm with your password", class: "settings-input" %>
      </div>
      <div class="settings-actions">
        <%= f.submit "Delete my account", class: "btn-danger",
            data: { turbo_confirm: "Really delete your account? This cannot be undone." } %>
      </div>
    <% end %>
  </div>
</div>
