<%= link_to "← Back", :back, class: "back-link" %>

<div class="profile-header">
  <div class="profile-avatar">
    <% if @user.avatar.attached? %>
      <%= image_tag @user.avatar_thumbnail, class: "avatar-img avatar-large" %>
    <% else %>
      <div class="avatar-initials avatar-large"><%= @user.initials %></div>
    <% end %>
  </div>
  <div class="profile-info">
    <h1>@<%= @user.username %></h1>
    <% if @user.bio.present? %>
      <p class="bio"><%= @user.bio %></p>
    <% else %>
      <p class="bio muted">No bio yet.</p>
    <% end %>
    <div class="profile-stats">
      <span><strong><%= @user.posts.count %></strong> Posts</span>
      <%= link_to profile_followers_path(@user.username), class: "profile-stat-link" do %>
        <strong><%= @user.followers.count %></strong> Followers
      <% end %>
      <%= link_to profile_following_path(@user.username), class: "profile-stat-link" do %>
        <strong><%= @user.following.count %></strong> Following
      <% end %>
    </div>
  </div>
  <div class="profile-actions">
    <% if @user == Current.user %>
      <%= link_to "Edit profile", edit_profile_path, class: "btn-ghost" %>
    <% elsif @blocked %>
      <%= button_to "Unblock", unblock_user_path(@user.username), method: :delete, class: "btn-ghost" %>
    <% else %>
      <% if Current.user.following?(@user) %>
        <%= button_to "Unfollow", unfollow_user_path(@user.username), method: :delete, class: "btn-ghost" %>
      <% else %>
        <%= button_to "Follow", follow_user_path(@user.username), method: :post, class: "btn-primary" %>
      <% end %>
      <%= button_to "Block", block_user_path(@user.username), method: :post, class: "btn-danger btn-small",
          data: { turbo_confirm: "Block @#{@user.username}? They won't see your posts and you won't see theirs." } %>
    <% end %>
  </div>
</div>

<% if @blocked %>
  <p class="empty-state">You have blocked @<%= @user.username %>.</p>
<% else %>
  <div class="posts-feed">
    <%= render @posts %>
  </div>
<% end %>
