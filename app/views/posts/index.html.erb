<h2 class="page-title">Feed</h2>

<%= form_with model: @post, class: "post-form" do |f| %>
  <% if @post.errors.any? %>
    <div class="error"><%= @post.errors.full_messages.to_sentence %></div>
  <% end %>
  <%= f.text_area :content, placeholder: "What's happening?", maxlength: 280, rows: 3 %>
  <div class="form-footer">
    <%= f.submit "Post", class: "btn-primary" %>
  </div>
<% end %>

<div class="posts-feed">
  <%= render @posts %>
</div>
