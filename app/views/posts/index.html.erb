<div class="feed-tabs">
  <%= link_to "All", root_path, class: "feed-tab #{@tab == "all" ? "active" : ""}" %>
  <%= link_to "Following", root_path(tab: "following"), class: "feed-tab #{@tab == "following" ? "active" : ""}" %>
</div>

<%= form_with model: @post, class: "post-form", multipart: true do |f| %>
  <% if @post.errors.any? %>
    <div class="error"><%= @post.errors.full_messages.to_sentence %></div>
  <% end %>
  <%= f.text_area :content, placeholder: "What's happening?", maxlength: 280, rows: 3,
      data: { charcount: true } %>
  <div class="form-footer">
    <span class="char-counter"><span class="char-remaining">280</span> chars left</span>
    <label class="btn-attach" title="Attach image">
      📎 <%= f.file_field :media, accept: "image/*,video/*", class: "attach-input" %>
    </label>
    <%= f.submit "Post", class: "btn-primary" %>
  </div>
<% end %>

<div class="posts-feed">
  <% if @posts.empty? %>
    <p class="empty-state">
      <% if @tab == "following" %>
        Nobody you follow has posted yet.
      <% else %>
        No posts yet. Be the first!
      <% end %>
    </p>
  <% else %>
    <%= render @posts %>
  <% end %>
</div>
