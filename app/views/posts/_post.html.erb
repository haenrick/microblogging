<div class="post <%= "reply" if post.parent_id %>">
  <div class="post-meta">
    <div class="post-avatar">
      <% if post.user.avatar.attached? %>
        <%= link_to profile_path(post.user.username) do %>
          <%= image_tag post.user.avatar_thumbnail, class: "avatar-img avatar-small" %>
        <% end %>
      <% else %>
        <%= link_to profile_path(post.user.username), class: "avatar-initials avatar-small" do %>
          <%= post.user.initials %>
        <% end %>
      <% end %>
    </div>
    <%= link_to "@#{post.user.username}", profile_path(post.user.username), class: "username" %>
    <%= link_to post_path(post), class: "post-time" do %>
      <%= time_ago_in_words(post.created_at) %> ago<% if post.edited_at %> · <span class="edited-marker">edited</span><% end %>
    <% end %>
    <% if post.expires_at %>
      <span class="expiry-badge expiry-<%= post.expiry_status %>">⏳ <%= post.expiry_label %></span>
    <% end %>
  </div>

  <div class="post-content"><%= post.content %></div>

  <% if post.media.attached? %>
    <div class="post-media">
      <% if post.media.video? %>
        <%= video_tag post.media, controls: true, class: "post-video" %>
      <% else %>
        <%= image_tag post.media, class: "post-image" %>
      <% end %>
    </div>
  <% end %>

  <div class="post-actions">
    <%= button_to like_post_path(post), method: :post, class: "btn-action #{post.liked_by?(Current.user) ? "liked" : ""}" do %>
      ♥ <%= post.likes_count %>
    <% end %>

    <button class="btn-action" onclick="this.closest('.post').querySelector('.reply-form').classList.toggle('hidden')">
      ↩ <%= post.replies.size %>
    </button>

    <% if post.user == Current.user %>
      <button class="btn-action" onclick="this.closest('.post').querySelector('.edit-form').classList.toggle('hidden')">
        ✎
      </button>
    <% end %>
  </div>

  <% if post.user == Current.user %>
    <div class="edit-form hidden">
      <%= form_with url: post_path(post), method: :patch, class: "post-form edit-form-inner" do |f| %>
        <%= f.text_area :content, value: post.content, maxlength: 280, rows: 3,
            data: { charcount: true } %>
        <div class="form-footer">
          <span class="char-counter"><span class="char-remaining"><%= 280 - post.content.length %></span> chars left</span>
          <%= f.submit "Save", class: "btn-primary btn-small" %>
          <%= button_to post_path(post), method: :delete, class: "btn-danger btn-small",
              data: { turbo_confirm: "Delete this post?" } do %>Delete<% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="reply-form hidden">
    <%= form_with url: reply_post_path(post), class: "post-form reply-form-inner" do |f| %>
      <%= f.text_area :content, placeholder: "Write a reply...", maxlength: 280, rows: 2,
          name: "post[content]", data: { charcount: true } %>
      <div class="form-footer">
        <span class="char-counter"><span class="char-remaining">280</span> chars left</span>
        <%= f.submit "Reply", class: "btn-primary btn-small" %>
      </div>
    <% end %>
  </div>

  <% if post.replies.any? %>
    <div class="replies">
      <%= render post.replies.order(:created_at) %>
    </div>
  <% end %>
</div>
