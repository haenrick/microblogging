<div class="post-actions" id="<%= dom_id(post, :actions) %>">
  <% if user_signed_in? %>
    <%= button_to like_post_path(post), method: :post,
        class: "btn-action #{post.liked_by?(Current.user) ? "liked" : ""}",
        data: { turbo_stream: true } do %>
      ♥ <%= post.likes_count %>
    <% end %>

    <button class="btn-action" data-action="click->toggle#toggleReply">
      ↩ <%= post.replies.size %>
    </button>

    <%= button_to boost_post_path(post),
        method: post.reposted_by?(Current.user) ? :delete : :post,
        class: "btn-action #{post.reposted_by?(Current.user) ? "boosted" : ""}",
        data: { turbo_stream: true },
        title: post.reposted_by?(Current.user) ? "Unboost" : "Boost" do %>
      ⇄ <%= post.reposts.size %>
    <% end %>

    <%= button_to bookmark_post_path(post),
        method: post.bookmarked_by?(Current.user) ? :delete : :post,
        class: "btn-action #{post.bookmarked_by?(Current.user) ? "bookmarked" : ""}",
        data: { turbo_stream: true },
        title: post.bookmarked_by?(Current.user) ? "Bookmark entfernen" : "Bookmark" do %>
      ✦
    <% end %>

    <% if post.user == Current.user %>
      <button class="btn-action" data-action="click->toggle#toggleEdit">
        ✎
      </button>
    <% end %>
  <% else %>
    <span class="btn-action">♥ <%= post.likes_count %></span>
    <span class="btn-action">↩ <%= post.replies.size %></span>
    <span class="btn-action">⇄ <%= post.reposts.size %></span>
  <% end %>
</div>
