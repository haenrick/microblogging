<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "fl4re" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#000000">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.webmanifest">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <% if user_signed_in? %>
      <% colors = Current.user.theme_colors %>
      <style nonce="<%= content_security_policy_nonce %>">
        :root {
          --green:      <%= colors[:primary] %>;
          --green-dim:  <%= colors[:dim] %>;
          --green-glow: <%= colors[:glow] %>;
        }
      </style>
    <% end %>
  </head>

  <body data-enter-to-post="<%= Current.user&.enter_to_post != false %>"
        <% if user_signed_in? && ENV["VAPID_PUBLIC_KEY"].present? %>
          data-controller="push-notifications"
          data-push-notifications-vapid-key-value="<%= ENV["VAPID_PUBLIC_KEY"] %>"
        <% end %>>
    <% if user_signed_in? %>
      <%= turbo_stream_from "notifications_#{Current.user.id}" %>
      <div class="app-layout">

        <%# Mobile header — only visible on small screens %>
        <header class="mobile-header" data-controller="mobile-nav">
          <%= link_to root_path, class: "mobile-logo" do %>
            > fl4re<span class="cursor">_</span>
          <% end %>
          <div class="mobile-header-right">
            <% mobile_inbox_count = Current.user.notifications.unread.count + Current.user.unread_messages_count %>
            <%= link_to notifications_path, class: "mobile-notif-link" do %>
              <%= render "notifications/badge", unread_count: mobile_inbox_count %>
            <% end %>
            <button class="mobile-avatar-btn" data-action="click->mobile-nav#toggle" aria-label="Menu">
              <% if Current.user.avatar.attached? %>
                <%= image_tag Current.user.avatar_thumbnail, class: "avatar-img avatar-small" %>
              <% else %>
                <div class="avatar-initials avatar-small"><%= Current.user.initials %></div>
              <% end %>
            </button>
          </div>
          <div class="mobile-backdrop hidden" data-mobile-nav-target="backdrop" data-action="click->mobile-nav#close"></div>
          <nav class="mobile-menu hidden" data-mobile-nav-target="menu">
            <div class="mobile-menu-inner">
              <ul class="nav-links">
                <li><%= link_to root_path, class: "nav-link", data: { action: "click->mobile-nav#close" } do %>> feed<% end %></li>
                <li><%= link_to search_path, class: "nav-link", data: { action: "click->mobile-nav#close" } do %>> search<% end %></li>
                <li><%= link_to discover_path, class: "nav-link", data: { action: "click->mobile-nav#close" } do %>> discover<% end %></li>
                <li><%= link_to notifications_path, class: "nav-link", data: { action: "click->mobile-nav#close" } do %>> inbox<% end %></li>
                <li><%= link_to profile_path(Current.user.username), class: "nav-link", data: { action: "click->mobile-nav#close" } do %>> profile<% end %></li>
                <li><%= link_to edit_profile_path, class: "nav-link", data: { action: "click->mobile-nav#close" } do %>> settings<% end %></li>
                <% if Current.user.admin? %>
                  <li><%= link_to admin_root_path, class: "nav-link nav-admin", data: { action: "click->mobile-nav#close" } do %>> admin<% end %></li>
                <% end %>
              </ul>
              <div class="mobile-menu-footer">
                <span class="sidebar-username">@<%= Current.user.username %></span>
                <%= button_to session_path, method: :delete, class: "btn-signout" do %>// sign out<% end %>
              </div>
            </div>
          </nav>
        </header>

        <nav class="sidebar">
          <div class="sidebar-top">
            <%= link_to root_path, class: "sidebar-logo" do %>
              > fl4re<span class="cursor">_</span>
            <% end %>
            <ul class="nav-links">
              <li><%= link_to root_path, class: "nav-link #{current_page?(root_path) ? "active" : ""}" do %>> feed<% end %></li>
              <li><%= link_to search_path, class: "nav-link #{current_page?(search_path) ? "active" : ""}" do %>> search<% end %></li>
              <li><%= link_to discover_path, class: "nav-link #{current_page?(discover_path) ? "active" : ""}" do %>> discover<% end %></li>
              <li>
                <% inbox_active = current_page?(notifications_path) || request.path.start_with?("/messages") %>
                <% total_inbox = Current.user.notifications.unread.count + Current.user.unread_messages_count %>
                <%= link_to notifications_path, class: "nav-link notif-nav-link #{inbox_active ? "active" : ""}" do %>
                  &gt; inbox
                  <% if total_inbox > 0 %>
                    <span class="notif-badge"><%= total_inbox %></span>
                  <% end %>
                <% end %>
              </li>
              <li><%= link_to profile_path(Current.user.username), class: "nav-link #{current_page?(profile_path(Current.user.username)) ? "active" : ""}" do %>> profile<% end %></li>
              <li><%= link_to edit_profile_path, class: "nav-link #{current_page?(edit_profile_path) ? "active" : ""}" do %>> settings<% end %></li>
              <% if Current.user.admin? %>
                <li><%= link_to admin_root_path, class: "nav-link nav-admin #{request.path.start_with?("/admin") ? "active" : ""}" do %>> admin<% end %></li>
              <% end %>
            </ul>
          </div>
          <div class="sidebar-bottom">
            <div class="sidebar-user">
              <div class="avatar-wrap">
                <% if Current.user.avatar.attached? %>
                  <%= image_tag Current.user.avatar_thumbnail, class: "avatar-img avatar-small" %>
                <% else %>
                  <div class="avatar-initials avatar-small"><%= Current.user.initials %></div>
                <% end %>
              </div>
              <span class="sidebar-username">@<%= Current.user.username %></span>
            </div>
            <%= button_to session_path, method: :delete, class: "btn-signout" do %>// sign out<% end %>
          </div>
          <div class="sidebar-version">v<%= FL4RE_VERSION %></div>
        </nav>

        <main class="main-content">
          <% if flash[:notice] %><p class="flash-notice">[ok] <%= flash[:notice] %></p><% end %>
          <% if flash[:alert] %><p class="flash-alert">[!] <%= flash[:alert] %></p><% end %>
          <% unless Current.user.email_verified? %>
            <div class="email-verification-banner">
              <span>[!] Bitte bestätige deine E-Mail-Adresse.</span>
              <%= button_to "> Mail erneut senden", resend_email_verification_path, method: :post, class: "btn-resend-verification" %>
            </div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <div class="auth-layout">
        <% if flash[:notice] %><p class="flash-notice">[ok] <%= flash[:notice] %></p><% end %>
        <% if flash[:alert] %><p class="flash-alert">[!] <%= flash[:alert] %></p><% end %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
