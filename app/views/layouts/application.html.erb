<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Microblog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#000000">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <% if user_signed_in? %>
      <% colors = Current.user.theme_colors %>
      <style>
        :root {
          --green:      <%= colors[:primary] %>;
          --green-dim:  <%= colors[:dim] %>;
          --green-glow: <%= colors[:glow] %>;
        }
      </style>
    <% end %>
    <script>
      document.addEventListener("keydown", function(e) {
        if (e.key === "Enter" && !e.shiftKey && e.target.matches(".post-form textarea")) {
          e.preventDefault();
          e.target.closest("form").requestSubmit();
        }
      });

      document.addEventListener("change", function(e) {
        if (!e.target.classList.contains("attach-input")) return;
        var label = e.target.closest(".btn-attach");
        var file = e.target.files[0];
        label.textContent = file ? "📎 " + file.name : "📎";
      });

      document.addEventListener("input", function(e) {
        if (!e.target.dataset.charcount) return;
        var max = parseInt(e.target.getAttribute("maxlength") || 280);
        var remaining = max - e.target.value.length;
        var counter = e.target.closest("form").querySelector(".char-remaining");
        if (!counter) return;
        counter.textContent = remaining;
        counter.closest(".char-counter").dataset.warn = remaining <= 20 ? "true" : "false";
      });
    </script>
  </head>

  <body>
    <% if user_signed_in? %>
      <div class="app-layout">
        <nav class="sidebar">
          <div class="sidebar-top">
            <%= link_to root_path, class: "sidebar-logo" do %>
              > microblog<span class="cursor">_</span>
            <% end %>
            <ul class="nav-links">
              <li><%= link_to root_path, class: "nav-link #{current_page?(root_path) ? "active" : ""}" do %>> feed<% end %></li>
              <li><%= link_to search_path, class: "nav-link #{current_page?(search_path) ? "active" : ""}" do %>> search<% end %></li>
              <li><%= link_to discover_path, class: "nav-link #{current_page?(discover_path) ? "active" : ""}" do %>> discover<% end %></li>
              <li><%= link_to profile_path(Current.user.username), class: "nav-link #{current_page?(profile_path(Current.user.username)) ? "active" : ""}" do %>> profile<% end %></li>
              <li><%= link_to edit_profile_path, class: "nav-link #{current_page?(edit_profile_path) ? "active" : ""}" do %>> settings<% end %></li>
            </ul>
          </div>
          <div class="sidebar-bottom">
            <div class="sidebar-user">
              <div class="avatar-wrap">
                <% if Current.user.avatar.attached? %>
                  <%= image_tag Current.user.avatar_thumbnail, class: "avatar-img avatar-small" %>
                <% else %>
                  <div class="avatar-initials avatar-small"><%= Current.user.initials %></div>
                <% end %>
              </div>
              <span class="sidebar-username">@<%= Current.user.username %></span>
            </div>
            <%= button_to session_path, method: :delete, class: "btn-signout" do %>// sign out<% end %>
          </div>
          <div class="sidebar-version">v<%= MICROBLOG_VERSION %></div>
        </nav>

        <main class="main-content">
          <% if flash[:notice] %><p class="flash-notice">[ok] <%= flash[:notice] %></p><% end %>
          <% if flash[:alert] %><p class="flash-alert">[!] <%= flash[:alert] %></p><% end %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <div class="auth-layout">
        <% if flash[:notice] %><p class="flash-notice">[ok] <%= flash[:notice] %></p><% end %>
        <% if flash[:alert] %><p class="flash-alert">[!] <%= flash[:alert] %></p><% end %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
