# fl4re — Umgebungsvariablen
# Kopieren nach .env und Werte anpassen (.env wird nicht in Git eingecheckt)

# Datenbank
DB_HOST=localhost
DB_USER=microblog
DB_PASSWORD=microblog_dev

# Rails
RAILS_ENV=production
PORT=4000
RAILS_MASTER_KEY=           # Inhalt aus config/master.key (cat config/master.key)
RAILS_LOG_LEVEL=info

# Optional: zusätzliche erlaubte Hosts (kommagetrennt)
# RAILS_ALLOWED_HOSTS=meine-domain.de,andere-domain.de

# E-Mail via Brevo SMTP (https://app.brevo.com → SMTP & API → SMTP)
BREVO_SMTP_USER=           # Deine Brevo-Login-E-Mail
BREVO_SMTP_KEY=            # SMTP Key aus Brevo-Dashboard (nicht dein Login-Passwort!)
