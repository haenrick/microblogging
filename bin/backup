#!/usr/bin/env bash
# fl4re — Datenbank-Backup
# Verwendung: bin/backup
# Empfohlen als Cronjob: 0 3 * * * /home/henrik/microblog/bin/backup

set -e

BACKUP_DIR="${BACKUP_DIR:-$HOME/backups/fl4re}"
DB_CONTAINER="${DB_CONTAINER:-fl4re_db}"
DB_USER="${DB_USER:-microblog}"
DB_NAME="${DB_NAME:-fl4re_development}"
KEEP_DAYS="${KEEP_DAYS:-30}"
DATE=$(date +%Y%m%d_%H%M%S)
FILE="$BACKUP_DIR/fl4re_$DATE.sql"

mkdir -p "$BACKUP_DIR"

echo "[fl4re backup] Starte Backup → $FILE"
docker exec "$DB_CONTAINER" pg_dump -U "$DB_USER" "$DB_NAME" > "$FILE"

# Alte Backups löschen
find "$BACKUP_DIR" -name "fl4re_*.sql" -mtime +"$KEEP_DAYS" -delete

echo "[fl4re backup] Fertig. Dateigröße: $(du -sh "$FILE" | cut -f1)"
